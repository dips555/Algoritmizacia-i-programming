class Vampire:
    def __init__(self, name, bloodlust):
        self.__name = name
        self.__bloodlust = bloodlust

    def get_bloodlust(self):
        return self.__bloodlust

    def set_bloodlust(self, value):
        if 0 < value <= 100:
            self.__bloodlust = value
        else:
            print("уровень жажды крови должен быть от 0 до 100!")

value = int(input("введите уровень крови: "))
vamp = Vampire("Дракула",100)
vamp.set_bloodlust(value)
print(f"Текущий уровень крови: {vamp.get_bloodlust()}")

