class DarkEntity:
    def __init__(self, name, species, danger_level):
        self.__name = name
        self.__species = species
        self.__danger_level = danger_level

boss = DarkEntity("Балор","Высший демон", 99)

print(f"Имя:{boss._DarkEntity__name}, вид: {boss._DarkEntity__species}, уровень угрозы:{boss._DarkEntity__danger_level}")
