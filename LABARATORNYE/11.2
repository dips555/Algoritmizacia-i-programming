for b in range(0, 11):           # быки
    for k in range(0, 21):       # коровы
        for t in range(0, 201):  # телята

            # проверка стоимости и условия покупки
            if 10 * b + 5 * k + 0.5 * t == 100 and (b + k + t >= 1):
                print("Быков =", b,
                      "Коров =", k,
                      "Телят =", t)
